{
  "name": "cms-mcp-server",
  "version": "1.0.0",
  "description": "MCP server exposing CMS healthcare datasets as callable tools in Claude conversations",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --config jest.config.cjs tests/unit.test.ts",
    "test:integration": "jest --config jest.config.cjs tests/integration.test.ts",
    "test:load": "tsx tests/load.test.ts",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.0.4",
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "node-cache": "^5.1.2",
    "pg": "^8.11.3",
    "rate-limiter-flexible": "^5.0.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
