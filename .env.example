# =============================================================================
# CMS MCP Server — Environment Configuration
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# Server
PORT=3000
LOG_LEVEL=info                    # debug | info | warn | error

# Authentication
# Generate a secure random key: openssl rand -hex 32
MCP_API_KEY=your_api_key_here

# Demo Mode (uses embedded sample data; no DB or external API required)
DEMO_MODE=true

# PostgreSQL (required if DEMO_MODE=false)
DATABASE_URL=postgresql://user:password@localhost:5432/cms_data
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Cache TTLs (seconds)
CACHE_TTL_REFERENCE=86400         # 24h — HCC grouper, MIPS measures, drug schedules
CACHE_TTL_TRANSACTION=300         # 5min — readmission rates, cost data

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MIN=100
RATE_LIMIT_WINDOW_MS=60000

# CMS External APIs (optional — used when DEMO_MODE=false)
CMS_PROVIDER_DATA_BASE_URL=https://data.cms.gov/provider-data/api/1
CMS_OPEN_PAYMENTS_BASE_URL=https://openpaymentsdata.cms.gov/api/1
CMS_DATA_BASE_URL=https://data.cms.gov/data-api/v1

# Audit Logging
AUDIT_LOG_PATH=./outputs/audit.log
QUERY_LOG_PATH=./outputs/queries.log
